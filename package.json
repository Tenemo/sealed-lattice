{
    "name": "sealed-lattice",
    "version": "0.0.5",
    "description": "A browser-native TypeScript package for sealed-lattice research prototypes, currently shipping a narrow SHA-256 helper while the post-quantum architecture remains intentionally unfrozen.",
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "MPL-2.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "imports": {
        "#root": "./src/index.ts",
        "#test-vectors/*": "./test-vectors/*",
        "#tools/*": "./tools/*"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tenemo/sealed-lattice.git"
    },
    "bugs": {
        "url": "https://github.com/Tenemo/sealed-lattice/issues"
    },
    "homepage": "https://tenemo.github.io/sealed-lattice/",
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "lint": "eslint . -c eslint.config.js",
        "eslint": "pnpm run lint",
        "eslint:fix": "eslint . --fix -c eslint.config.js",
        "knip": "knip",
        "typecheck": "tsc",
        "tsc": "pnpm run typecheck",
        "guard:no-math-random": "tsx ./tests/guards/check-no-math-random.ts",
        "verify:package-surface": "tsx ./tools/ci/verify-package-surface.ts",
        "verify:vectors": "tsx ./tools/ci/verify-vectors.ts",
        "smoke:pack": "tsx ./tools/ci/verify-packed-package.ts",
        "vectors:core": "tsx ./tools/generate-core-vectors.ts",
        "bench:micro": "tsx ./tools/benchmarks/microbench.ts",
        "check": "pnpm run lint && pnpm run typecheck && pnpm run knip && pnpm run guard:no-math-random && pnpm run verify:package-surface && pnpm run verify:vectors && pnpm run test:node",
        "prebuild": "pnpm run check && pnpm exec del-cli dist",
        "build": "tsc --project tsconfig.build.json",
        "build:skip": "pnpm exec del-cli dist && tsc --project tsconfig.build.json",
        "test:node": "vitest --project node --run",
        "test:browser": "vitest --project browser --run",
        "test": "pnpm run test:node && pnpm run test:browser",
        "test:watch": "vitest --project node --watch",
        "coverage:node": "vitest --project node --run --coverage",
        "coverage:badge": "pnpm run coverage:node && tsx ./tools/generate-coverage-badge.ts",
        "verify:docs:build": "tsx ./tools/ci/verify-docs-build.ts",
        "docs:ci": "pnpm run verify:docs && pnpm run coverage:badge && pnpm run docs:build:site && pnpm run verify:docs:build",
        "ci": "pnpm run check && pnpm run build:skip && pnpm run smoke:pack && pnpm run test:browser && pnpm run docs:ci",
        "docs:api": "pnpm exec del-cli docs/src/content/docs/api/reference && tsx ./node_modules/typedoc/bin/typedoc --options typedoc.config.mjs && tsx ./typedoc/postprocess-site-docs.ts",
        "docs:dev": "pnpm run docs:api && astro dev --root docs",
        "docs:build": "pnpm run verify:docs && pnpm run docs:build:site",
        "docs:build:site": "pnpm exec del-cli docs/dist && astro build --root docs --silent",
        "docs:preview": "astro preview --root docs",
        "verify:docs": "pnpm run docs:api && tsx ./typedoc/verify-docs.ts",
        "prepublish:public": "pnpm run ci",
        "publish:public": "pnpm publish --access public",
        "prepare": "husky"
    },
    "devDependencies": {
        "@astrojs/mdx": "^5.0.3",
        "@astrojs/starlight": "^0.38.3",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@fontsource/ibm-plex-sans": "^5.2.8",
        "@fontsource/jetbrains-mono": "^5.2.8",
        "@types/node": "^25.5.2",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "@vitest/browser-playwright": "^4.1.3",
        "@vitest/coverage-v8": "^4.1.3",
        "astro": "^6.1.5",
        "del-cli": "^7.0.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-only-error": "^1.0.2",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "knip": "^5.67.0",
        "playwright": "^1.59.1",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typedoc": "^0.28.18",
        "typedoc-plugin-markdown": "^4.11.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.7",
        "vitest": "^4.1.3"
    },
    "engines": {
        "node": ">=24.14.1"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "unrs-resolver"
        ]
    },
    "type": "module",
    "keywords": [
        "cryptography",
        "security",
        "post-quantum",
        "lattice",
        "threshold-encryption",
        "research-prototype",
        "webcrypto",
        "typescript-cryptography",
        "data-protection",
        "privacy"
    ]
}
