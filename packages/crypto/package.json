{
  "name": "@sealed-lattice/crypto",
  "version": "0.0.0",
  "private": true,
  "description": "Internal crypto provider package for the sealed-lattice workspace.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "check": "tsc --project tsconfig.json --pretty false --noEmit",
    "build": "pnpm exec del-cli dist && tsc --project tsconfig.build.json",
    "test:node": "vitest --project node --run tests/node/**/*.test.ts"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  }
}
