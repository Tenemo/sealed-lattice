{
  "name": "@sealed-lattice/wasm",
  "version": "0.0.0",
  "private": true,
  "description": "Internal WASM loader package for the sealed-lattice workspace.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "check": "tsc --project tsconfig.json --pretty false --noEmit",
    "build:wasm": "tsx ../../tools/ci/build-wasm-placeholder.ts",
    "build": "pnpm exec del-cli dist && tsc --project tsconfig.json && pnpm run build:wasm",
    "test:node": "vitest --project node --run tests/node/**/*.test.ts",
    "test:browser": "vitest --project browser-desktop --project browser-mobile --run tests/browser/**/*.browser.test.ts"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  }
}
