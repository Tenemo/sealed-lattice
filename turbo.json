{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "//#lint:workspace": {
      "outputs": []
    },
    "//#eslint:fix:workspace": {
      "cache": false,
      "outputs": []
    },
    "//#tsc:workspace": {
      "outputs": []
    },
    "//#boundary:workspace": {
      "outputs": []
    },
    "//#vectors:workspace": {
      "outputs": []
    },
    "//#vectors:generate:workspace": {
      "outputs": [
        "test-vectors/manifest.json"
      ]
    },
    "//#knip:workspace": {
      "outputs": []
    },
    "//#check:workspace": {
      "outputs": []
    },
    "//#test:node:workspace": {
      "dependsOn": [
        "sealed-lattice#build",
        "@sealed-lattice/protocol#build",
        "@sealed-lattice/crypto#build",
        "@sealed-lattice/wasm#build",
        "@sealed-lattice/testkit#build"
      ],
      "outputs": []
    },
    "//#test:browser:workspace": {
      "dependsOn": [
        "sealed-lattice#build",
        "@sealed-lattice/protocol#build",
        "@sealed-lattice/crypto#build",
        "@sealed-lattice/wasm#build",
        "@sealed-lattice/testkit#build"
      ],
      "outputs": []
    },
    "//#coverage:node:workspace": {
      "dependsOn": [
        "sealed-lattice#build",
        "@sealed-lattice/protocol#build",
        "@sealed-lattice/crypto#build",
        "@sealed-lattice/wasm#build",
        "@sealed-lattice/testkit#build"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "//#coverage:badge:workspace": {
      "dependsOn": [
        "//#coverage:node:workspace"
      ],
      "outputs": [
        "docs/public/coverage-badge.json",
        "docs/public/coverage-summary.json"
      ]
    },
    "//#docs:api:workspace": {
      "dependsOn": [
        "sealed-lattice#build",
        "@sealed-lattice/protocol#build",
        "@sealed-lattice/crypto#build",
        "@sealed-lattice/wasm#build",
        "@sealed-lattice/testkit#build"
      ],
      "outputs": [
        "docs/src/content/docs/api/reference/**"
      ]
    },
    "//#docs:dev:workspace": {
      "cache": false,
      "dependsOn": [
        "//#docs:api:workspace"
      ],
      "persistent": true,
      "outputs": []
    },
    "//#docs:build:site:workspace": {
      "dependsOn": [
        "//#docs:api:workspace"
      ],
      "outputs": [
        "docs/dist/**"
      ]
    },
    "//#docs:preview:workspace": {
      "cache": false,
      "dependsOn": [
        "//#docs:build:site:workspace"
      ],
      "persistent": true,
      "outputs": []
    },
    "//#verify:docs:workspace": {
      "dependsOn": [
        "//#docs:api:workspace"
      ],
      "outputs": []
    },
    "//#smoke:pack:workspace": {
      "dependsOn": [
        "sealed-lattice#build"
      ],
      "outputs": []
    },
    "//#smoke:pack:npm:workspace": {
      "dependsOn": [
        "sealed-lattice#build"
      ],
      "outputs": []
    },
    "build:wasm": {
      "outputs": [
        "dist/*.wasm"
      ]
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "check": {
      "dependsOn": [
        "^check"
      ],
      "outputs": []
    },
    "test:node": {
      "dependsOn": [],
      "outputs": []
    },
    "test:browser": {
      "dependsOn": [],
      "outputs": []
    },
    "smoke:pack": {
      "dependsOn": [
        "build"
      ],
      "outputs": []
    },
    "smoke:pack:npm": {
      "dependsOn": [
        "build"
      ],
      "outputs": []
    }
  }
}
